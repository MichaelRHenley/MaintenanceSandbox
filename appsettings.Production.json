  //
  // Required environment variables on the VM:
  //
  //   Ai__ApiKey                    = sk-ant-...   (Anthropic API key)
  //   ConnectionStrings__DefaultConnection         (Azure SQL business DB)
  //   ConnectionStrings__DirectoryConnection       (Azure SQL directory DB)
  //
  //   Analytics__GA4MeasurementId   = G-XXXXXXXXXX  (Google Analytics 4)
  //   Analytics__ClarityProjectId   = XXXXXXXXXX    (Microsoft Clarity)
  //
  //   Demo__EmailLinkSecret         = <random 32+ char secret for HMAC signing>
  //   Email__SmtpHost               = smtp.sendgrid.net  (or your SMTP provider)
  //   Email__SmtpPort               = 587
  //   Email__SmtpUser               = apikey
  //   Email__SmtpPassword           = SG.xxxx...
  //   Email__FromAddress            = noreply@yourdomain.com
  //
  // Use double-underscore (__) to map to nested JSON sections.
  // Set via: System Properties > Environment Variables  OR
  //          Azure App Service > Configuration > Application Settings

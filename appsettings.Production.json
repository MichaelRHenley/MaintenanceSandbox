{
  // Production overrides. Secrets come from VM environment variables — never commit them here.
  // Use double-underscore (__) separator in env var names to map nested JSON keys:
  //   ConnectionStrings__DefaultConnection
  //   ConnectionStrings__DirectoryConnection
  //   Ai__ApiKey
  //   Demo__EmailLinkSecret
  //   Email__SmtpHost / SmtpPort / SmtpUser / SmtpPassword / FromAddress
  //
  // Set via: IIS Manager > Configuration Editor > system.webServer/aspNetCore > environmentVariables
  // OR: Windows System Properties > Environment Variables (system-wide)

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },

  "AllowedHosts": "*",

  // Override base appsettings.json: disable demo mode in production.
  "Demo": {
    "Enabled": false,
    "SeedOnStartup": false
  },

  // Data Protection key ring — directory must exist and be writable by the app pool identity.
  // Keys are rotated automatically every 90 days. Do not delete this folder between deployments.
  "DataProtection": {
    "KeysPath": "C:\\inetpub\\dpkeys\\MaintenanceSandbox"
  }
}


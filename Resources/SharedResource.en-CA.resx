	<!-- Privacy page -->
	<data name="Privacy_Title" xml:space="preserve">
	  <value>Privacy Policy</value>
	</data>
	<data name="Privacy_LastUpdated" xml:space="preserve">
	  <value>Last updated: June 2025</value>
	</data>
	<data name="Privacy_S1_Title" xml:space="preserve">
	  <value>1. What We Collect</value>
	</data>
	<data name="Privacy_S1_Intro" xml:space="preserve">
	  <value>When you use Sentinel, we collect:</value>
	</data>
	<data name="Privacy_S1_Item_Account" xml:space="preserve">
	  <value>&lt;strong&gt;Account information&lt;/strong&gt; — name, email address, and role within your organisation.</value>
	</data>
	<data name="Privacy_S1_Item_Operational" xml:space="preserve">
	  <value>&lt;strong&gt;Operational data&lt;/strong&gt; — maintenance requests, comments, status updates, equipment records, and work-centre assignments that you and your team enter into the application.</value>
	</data>
	<data name="Privacy_S1_Item_Usage" xml:space="preserve">
	  <value>&lt;strong&gt;Usage data&lt;/strong&gt; — page visits, feature interactions, and browser/device type for performance monitoring and product improvement.</value>
	</data>
	<data name="Privacy_S1_Item_Ai" xml:space="preserve">
	  <value>&lt;strong&gt;AI interaction content&lt;/strong&gt; — when you use the AI help or AI suggestion features, the text of your request (including relevant maintenance context) is sent to Anthropic's Claude API for processing. No personally identifiable information is intentionally included in AI prompts.</value>
	</data>
	<data name="Privacy_S2_Title" xml:space="preserve">
	  <value>2. How We Use Your Data</value>
	</data>
	<data name="Privacy_S2_Item1" xml:space="preserve">
	  <value>To deliver and operate the Sentinel application for your tenant.</value>
	</data>
	<data name="Privacy_S2_Item2" xml:space="preserve">
	  <value>To provide real-time collaboration features (comments, status updates) via SignalR.</value>
	</data>
	<data name="Privacy_S2_Item3" xml:space="preserve">
	  <value>To generate AI-assisted maintenance suggestions and contextual help.</value>
	</data>
	<data name="Privacy_S2_Item4" xml:space="preserve">
	  <value>To send transactional emails (invite links, notifications) via Azure Communication Services.</value>
	</data>
	<data name="Privacy_S2_Item5" xml:space="preserve">
	  <value>To improve product reliability and performance.</value>
	</data>
	<data name="Privacy_S2_NoSell" xml:space="preserve">
	  <value>We do not sell your data to third parties.</value>
	</data>
	<data name="Privacy_S3_Title" xml:space="preserve">
	  <value>3. Tenant Isolation</value>
	</data>
	<data name="Privacy_S3_Body" xml:space="preserve">
	  <value>All operational data is scoped to your organisation's tenant. Row-level isolation is enforced at the database layer — no tenant can access another tenant's data. Demo sessions are isolated the same way and are automatically purged after two hours.</value>
	</data>
	<data name="Privacy_S4_Title" xml:space="preserve">
	  <value>4. Third-Party Services</value>
	</data>
	<data name="Privacy_S4_Item_Anthropic" xml:space="preserve">
	  <value>&lt;strong&gt;Anthropic (Claude)&lt;/strong&gt; — AI features send anonymised maintenance context to Claude's API. Anthropic's data processing agreement applies. No prompts are used to train models.</value>
	</data>
	<data name="Privacy_S4_Item_Azure" xml:space="preserve">
	  <value>&lt;strong&gt;Microsoft Azure&lt;/strong&gt; — the application is hosted on Azure infrastructure. Data is stored in Azure SQL Database. Azure Communication Services is used for email delivery.</value>
	</data>

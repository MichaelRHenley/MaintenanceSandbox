	</data>
	<data name="Privacy_S2_Item1" xml:space="preserve">
		<value>Sentinel-sovelluksen tarjoamiseen ja käyttämiseen vuokralaisellesi.</value>
	</data>
	<data name="Privacy_S2_Item2" xml:space="preserve">
		<value>Reaaliaikaisten yhteistyöominaisuuksien (kommentit, tilapäivitykset) tarjoamiseen SignalR:n kautta.</value>
	</data>
	<data name="Privacy_S2_Item3" xml:space="preserve">
		<value>Tekoälyavusteisten kunnossapitoehdotusten ja kontekstuaalisen avun luomiseen.</value>
	</data>
	<data name="Privacy_S2_Item4" xml:space="preserve">
		<value>Tapahtumaviestien lähettämiseen (kutsulinkit, ilmoitukset) Azure Communication Servicesin kautta.</value>
	</data>
	<data name="Privacy_S2_Item5" xml:space="preserve">

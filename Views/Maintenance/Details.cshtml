@model MaintenanceSandbox.Models.MaintenanceRequest
@using Microsoft.Extensions.Localization
@using System.Globalization
@using System.Linq
@using MaintenanceSandbox.Services
@inject IStringLocalizer<SharedResource> SR

@{
    ViewData["Title"] = SR["Maint_Details_Title"];

    // 🔹 Localized status text + CSS class
    var rawStatus = Model.Status ?? "";
    var statusKey = rawStatus.ToLowerInvariant() switch
    {
        "new" => "Maint_Status_New",
        "in progress" => "Maint_Status_InProgress",
        "waiting on parts" => "Maint_Status_WaitingOnParts",
        "resolved" => "Maint_Status_Resolved",
        "closed" => "Maint_Status_Closed",
        _ => null
    };
    var localizedStatus = statusKey is null ? rawStatus : SR[statusKey];

    var statusClass = rawStatus.ToLowerInvariant() switch
    {
        "resolved" => "badge-status-closed",
        _ => "badge-status-open"
    };

    // 🔹 Localized priority text + CSS class
    var rawPriority = Model.Priority ?? "";
    var priorityKey = rawPriority.ToLowerInvariant() switch
    {
        "high" => "Maint_Create_Priority_High",
        "medium" => "Maint_Create_Priority_Medium",
        "low" => "Maint_Create_Priority_Low",
        _ => null
    };
    var localizedPriority = priorityKey is null ? rawPriority : SR[priorityKey];

    var priorityClass = rawPriority.ToLowerInvariant() switch
    {
        "high" => "badge-priority-high",
        "medium" => "badge-priority-medium",
        _ => "badge-priority-low"
    };

    string FormatDate(DateTime dt) =>
        dt.ToString("f", CultureInfo.CurrentUICulture);

    var role = ViewBag.DemoUserRole as string ?? "";
    bool canEditStatus = !string.Equals(role, "Operator", StringComparison.OrdinalIgnoreCase);
}
@{
    ViewData["AiModuleKey"] = "EM_Details";
}


<div class="container py-4">
    <div class="sentinel-card">
        <div class="p-3 p-md-4">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2 position-relative">

            <div class="d-flex gap-2">
                <span class="badge-status @statusClass" data-role="status-badge">@localizedStatus</span>
                <span class="badge-status @priorityClass" data-role="priority-badge">@localizedPriority</span>
            </div>

            <div class="d-flex gap-2 align-items-center">
                @await Html.PartialAsync("_AiHelpLauncher")
                <!-- existing live indicator + buttons -->
                <span id="live-indicator"
                      class="sentinel-live-indicator sentinel-live-indicator--offline">
                    <span class="dot"></span>
                    <span class="label">@SR["LiveIndicator_Label_Connecting"]</span>
                </span>

                <a asp-action="Index" class="btn btn-sentinel-ghost btn-sm">
                    @SR["Maint_Details_Button_BackToList"]
                </a>

                <form asp-action="MarkResolved"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="btn btn-sentinel-primary btn-sm">
                        @SR["Maint_Details_Button_MarkResolved"]
                    </button>
                </form>
            </div>
        </div>


            <!-- RESPONDERS -->
            <div class="mb-4 small">
                <span class="text-muted">@SR["Maint_Details_Label_RespondersPresent"]</span>
                <div id="presence-list" class="mt-1">
                    <span class="text-muted">
                        @SR["Maint_Details_Label_RespondersConnecting"]
                    </span>
                </div>
            </div>

            <!-- MAIN CONTENT: LEFT / RIGHT COLUMNS -->
            <div class="row gx-4 gy-4">

                <!-- LEFT COLUMN -->
                <div class="col-lg-6">

                    <div class="glass-card mb-3">
                        <dl class="row small mb-0">
                            <dt class="col-4">@SR["Maint_Details_Label_Site"]</dt>
                            <dd class="col-8">@Model.Site</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_Area"]</dt>
                            <dd class="col-8">@Model.Area</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_WorkCenter"]</dt>
                            <dd class="col-8">@(Model.WorkCenter?.DisplayName ?? "-")</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_Equipment"]</dt>
                            <dd class="col-8">@(Model.Equipment?.DisplayName ?? "-")</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_Status"]</dt>
                            <dd class="col-8" data-role="status-value">@localizedStatus</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_Priority"]</dt>
                            <dd class="col-8" data-role="priority-value">@localizedPriority</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_RequestedBy"]</dt>
                            <dd class="col-8">@Model.RequestedBy</dd>

                            <dt class="col-4">@SR["Maint_Details_Label_CreatedAt"]</dt>
                            <dd class="col-8">@FormatDate(Model.CreatedAt)</dd>

                            @if (Model.ResolvedAt.HasValue)
                            {
                                <dt class="col-4">@SR["Maint_Details_Label_ResolvedAt"]</dt>
                                <dd class="col-8">@FormatDate(Model.ResolvedAt.Value)</dd>
                            }

                            <dt class="col-4">@SR["Maint_Details_Label_Description"]</dt>
                            <dd class="col-8">@Model.Description</dd>
                        </dl>
                    </div>

                    <!-- WORKFLOW EDIT -->
                @if (canEditStatus)
                {
                    var statusOptions = ViewBag.StatusOptions as IEnumerable<SelectListItem>
                    ?? Enumerable.Empty<SelectListItem>();
                    var priorityOptions = ViewBag.PriorityOptions as IEnumerable<SelectListItem>
                    ?? Enumerable.Empty<SelectListItem>();


                        <div class="glass-card glass-card--accent mt-3">
                            <div class="mb-2">
                                <h6 class="glass-card-label mb-1">
                                    @SR["Maint_Details_Section_UpdateWorkflow"]
                                </h6>
                                <div class="small text-muted">
                                    @SR["Maint_Details_Hint_WorkflowForLeads"]
                                </div>
                            </div>

                            <form asp-action="UpdateRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />

                                <div class="row g-2 align-items-end">
                                    <div class="col-sm-6">
                                        <label class="form-label small mb-1">
                                            @SR["Maint_Details_Label_Status"]
                                        </label>
                                    <select name="status" class="form-select form-select-sm">
                                        @foreach (var s in statusOptions)
                                        {
                                            <option value="@s.Value" selected="@(Model.Status == s.Value)">
                                                @s.Text
                                            </option>
                                        }
                                    </select>
                                    </div>

                                    <div class="col-sm-6">
                                        <label class="form-label small mb-1">
                                            @SR["Maint_Details_Label_Priority"]
                                        </label>
                                    <select name="priority" class="form-select form-select-sm">
                                        @foreach (var p in priorityOptions)
                                        {
                                            <option value="@p.Value" selected="@(Model.Priority == p.Value)">
                                                @p.Text
                                            </option>
                                        }
                                    </select>
                                    </div>
                                </div>

                                <div class="text-end mt-2">
                                    <button type="submit"
                                            class="btn btn-sentinel-primary btn-sm px-3">
                                        @SR["Maint_Details_Button_UpdateStatus"]
                                    </button>
                                </div>
                            </form>
                        </div>
                    }


                    <div id="ai-fix-result"></div>

                    @{
                        // Suggestions provided by controller: ViewBag.Suggestions
                        var suggestions = ViewBag.Suggestions as IEnumerable<SuggestionItem>
                        ?? Enumerable.Empty<SuggestionItem>();
                    }

                    @if (suggestions.Any())
                    {
                        <hr class="mt-4" />

                        <h6 class="text-uppercase small text-muted mb-1">
                            @SR["Maint_Details_Section_Suggestions"]
                        </h6>
                        <div class="small text-muted mb-2">
                            @SR["Maint_Details_Hint_Suggestions"]
                        </div>

                        <div class="d-flex flex-column gap-2">
                            @foreach (var s in suggestions)
                            {
                                <div class="sentinel-suggestion-tile">
                                    <div class="sentinel-suggestion-header">
                                        <span class="sentinel-suggestion-icon">🛠</span>
                                        <span class="sentinel-suggestion-text">
                                            @s.Text
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- RIGHT COLUMN -->
                <div class="col-lg-6">
                    <div class="glass-card d-flex flex-column">
                        <h6 class="glass-card-label mb-2">
                            @SR["Maint_Details_Section_Comments"]
                        </h6>

                        <div id="typing-indicator-@Model.Id"
                             class="typing-indicator small text-muted d-none mb-2">
                        </div>

                        <div id="comments-container" class="mb-3 flex-grow-1">
                            @await Html.PartialAsync("_CommentsList", Model)
                        </div>

                        <h6 class="glass-card-label mt-2 mb-1">
                            @SR["Maint_Details_Label_NewComment"]
                        </h6>

                        <form asp-action="AddMessage" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="maintenanceRequestId" value="@Model.Id" />

                            <textarea id="CommentText"
                                      name="text"
                                      class="form-control mb-2"
                                      rows="3"
                                      required></textarea>

                            <input type="hidden" name="sender" value="@ViewBag.DemoUserName" />

                            <button type="submit" class="btn btn-sentinel-primary btn-sm px-3">
                                @SR["Maint_Details_Button_AddComment"]
                            </button>
                                        </form>
                                    </div>
                                </div>

                                <!-- AI TROUBLESHOOTING INSIGHT (full-width, auto-loads on open) -->
                                <div class="mt-4">
                                    <div id="ai-insight-panel" class="glass-card glass-card--accent">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h6 class="glass-card-label mb-0">
                                                <span class="me-2">🤖</span>@SR["AiInsight_Title"]
                                            </h6>
                                            <div class="d-flex gap-2 align-items-center">
                                                <span id="ai-insight-timestamp" class="text-muted" style="font-size:0.72rem;"></span>
                                                <button id="ai-insight-refresh"
                                                        class="btn btn-sentinel-ghost btn-sm py-0"
                                                        title="@SR["AiInsight_Tooltip_Refresh"]"
                                                        style="font-size:0.78rem;">
                                                    🔄 @SR["AiInsight_Button_Refresh"]
                                                </button>
                                            </div>
                                        </div>

                                        <div id="ai-insight-loading" class="text-center py-3">
                                            <span class="spinner-border spinner-border-sm me-2" role="status"
                                                  style="color:var(--sentinel-accent);"></span>
                                            <span class="text-muted small">@SR["AiInsight_Loading"]</span>
                                        </div>

                                        <div id="ai-insight-content" class="small d-none"></div>

                                        <div id="ai-insight-error" class="small text-muted py-2 d-none">
                                            ⚠️ @SR["AiInsight_Error_Unavailable"] <a href="#" id="ai-insight-retry" class="text-info">@SR["AiInsight_Link_TryAgain"]</a>
                                        </div>

                                        <div id="ai-insight-actions" class="d-none mt-3 d-flex gap-2 flex-wrap">
                                            <a asp-action="Index"
                                               asp-route-search="@(Model.Equipment?.DisplayName ?? "")"
                                               class="btn btn-sentinel-ghost btn-sm" style="font-size:0.78rem;">
                                                🔍 @SR["AiInsight_Button_ViewSimilar"]
                                            </a>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            </div>
                        </div>
    </div>



@section Scripts {
    <script>
        (function () {
            const btn = document.getElementById("askAiBtn");
            if (!btn) return;

            btn.addEventListener("click", async () => {
                const form   = document.getElementById("suggestFixForm");
                const token  = form.querySelector('input[name="__RequestVerificationToken"]').value;
                const id     = form.querySelector('input[name="id"]').value;
                const result = document.getElementById("ai-fix-result");
                const label  = btn.innerHTML;

                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span> Thinking&hellip;';
                result.innerHTML = "";

                try {
                    const resp = await fetch('@Url.Action("SuggestFix", "Maintenance")', {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded" },
                        body: new URLSearchParams({ id, __RequestVerificationToken: token })
                    });

                    if (resp.status === 429) {
                            result.innerHTML = '<div class="alert alert-warning mt-2 small mb-0">⚠️ <strong>Demo limit reached.</strong> This session has used its AI quota — suggestions will be available again in the next hour.</div>';
                        } else if (!resp.ok) {
                            throw new Error(resp.status);
                        } else {

                        const data = await resp.json();

                        if (data.suggestion) {
                        // Escape HTML then convert newlines to <br>
                        const tmp = document.createElement("div");
                        tmp.textContent = data.suggestion;
                        const safe = tmp.innerHTML.replace(/\n/g, "<br>");

                        result.innerHTML = `
                            <div class="card mt-2 border-warning">
                                <div class="card-header bg-warning text-dark">AI Fix Suggestions (Sentinel)</div>
                                <div class="card-body small">
                                    ${safe}
                                    <p class="mt-3 mb-0 text-muted">These are AI-generated suggestions based on the ticket description and comments. Always follow your plant&rsquo;s safety procedures and lockout/tagout policies.</p>
                                </div>
                            </div>`;
                    } else {
                        result.innerHTML = '<p class="text-muted small mt-2">No suggestions returned.</p>';
                    }
                    }
                } catch {
                    result.innerHTML = '<p class="text-danger small mt-2">Could not fetch AI suggestions — please try again.</p>';
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = label;
                }
            });
        })();
    </script>
    <script>
        (function () {
            const requestId = parseInt('@Model.Id', 10);
            const userName = "@(ViewBag.DemoUserName ?? "Unknown")";
            const userRole = "@(ViewBag.DemoUserRole ?? "")";

            const presenceContainer = document.getElementById("presence-list");
            const liveIndicator = document.getElementById("live-indicator");
            const liveLabel = liveIndicator ? liveIndicator.querySelector(".label") : null;

            function setLiveState(mode) {
                if (!liveIndicator || !liveLabel) return;

                liveIndicator.classList.remove(
                    "sentinel-live-indicator--offline",
                    "sentinel-live-indicator--online",
                    "sentinel-live-indicator--connecting"
                );

                switch (mode) {
                    case "online":
                        liveIndicator.classList.add("sentinel-live-indicator--online");
                        liveLabel.textContent = "@SR["LiveIndicator_Label_Live"]";
                        break;
                    case "connecting":
                        liveIndicator.classList.add("sentinel-live-indicator--connecting");
                        liveLabel.textContent = "@SR["LiveIndicator_Label_Connecting"]";
                        break;
                    default:
                        liveIndicator.classList.add("sentinel-live-indicator--offline");
                        liveLabel.textContent = "@SR["LiveIndicator_Label_Offline"]";
                        break;
                }

                // Keep global footer pill in sync, if present
                if (window.sentinelUpdateLiveIndicator) {
                    const state = mode === "online" ? "ok" : "offline";
                    window.sentinelUpdateLiveIndicator(state, { suppressToast: true });
                }
            }

            function renderPresence(names) {
                if (!presenceContainer) return;

                if (!names || names.length === 0) {
                    presenceContainer.innerHTML =
                        '<span class="text-muted small">@SR["Maint_Details_Label_NoResponders"]</span>';
                    return;
                }

                const html = names
                    .map(x => `<span class="badge bg-info text-dark me-1 mb-1">${x}</span>`)
                    .join("");

                presenceContainer.innerHTML = html;
            }

            // SignalR connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/maintenance")
                .withAutomaticReconnect()
                .build();

            setLiveState("connecting");

            // Presence updates
            connection.on("ResponderPresenceChanged", function (reqId, list) {
                if (reqId !== requestId) return;
                renderPresence(list);
            });

            connection.onreconnecting(() => {
                setLiveState("connecting");
            });

            connection.onreconnected(() => {
                setLiveState("online");
                connection.invoke("JoinRequestGroup", requestId, userName)
                    .catch(err => console.error(err.toString()));
            });

            connection.onclose(() => {
                setLiveState("offline");
            });

            connection.start()
                .then(function () {
                    setLiveState("online");
                    return connection.invoke("JoinRequestGroup", requestId, userName);
                })
                .catch(function (err) {
                    console.error(err.toString());
                    setLiveState("offline");
                });

            // Leave group when navigating away
            window.addEventListener("beforeunload", function () {
                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("LeaveRequestGroup", requestId, userName)
                        .catch(function () { /* ignore */ });
                }
            });

            // 🔹 Typing indicator wiring
            const typingIndicator = document.getElementById("typing-indicator-" + requestId);
            const chatInput = document.getElementById("CommentText");

            let typingTimeout = null;
            let lastTypingSent = 0;
            const TYPING_DEBOUNCE_MS = 800;
            const TYPING_IDLE_MS = 2000;

            const displayName = userName;
            const role = userRole;

            function sendStartTyping() {
                const now = Date.now();
                if (now - lastTypingSent < TYPING_DEBOUNCE_MS) return;
                lastTypingSent = now;

                connection.invoke("StartTyping", requestId, displayName, role)
                    .catch(err => console.error("StartTyping error:", err));
            }

            function sendStopTyping() {
                connection.invoke("StopTyping", requestId, displayName, role)
                    .catch(err => console.error("StopTyping error:", err));
            }

            if (chatInput) {
                chatInput.addEventListener("input", () => {
                    if (!chatInput.value.trim()) {
                        sendStopTyping();
                        return;
                    }

                    sendStartTyping();

                    if (typingTimeout) clearTimeout(typingTimeout);
                    typingTimeout = setTimeout(() => {
                        sendStopTyping();
                    }, TYPING_IDLE_MS);
                });

                chatInput.addEventListener("blur", () => {
                    sendStopTyping();
                });
            }

            // Listen for typing events from others
            connection.on("UserTyping", payload => {
                if (!payload || payload.requestId !== requestId) return;

                if (payload.isTyping) {
                    typingIndicator.textContent = `${payload.label} is typing…`;
                    typingIndicator.classList.remove("d-none");
                    typingIndicator.classList.add("dotting");
                } else {
                    typingIndicator.textContent = "";
                    typingIndicator.classList.add("d-none");
                    typingIndicator.classList.remove("dotting");
                }
            });

            // 🔹 Live status/priority updates
            connection.on("RequestUpdated", payload => {
                if (!payload) return;

                const changedId = payload.requestId ?? payload.id;
                if (changedId !== requestId) return;

                const statusBadge = document.querySelector("[data-role='status-badge']");
                const priorityBadge = document.querySelector("[data-role='priority-badge']");
                const statusValue = document.querySelector("[data-role='status-value']");
                const priorityValue = document.querySelector("[data-role='priority-value']");

                if (statusBadge) statusBadge.textContent = payload.status;
                if (priorityBadge) priorityBadge.textContent = payload.priority;
                if (statusValue) statusValue.textContent = payload.status;
                if (priorityValue) priorityValue.textContent = payload.priority;
            });

            // 🔹 Reload comments list when server says comments changed
            connection.on("CommentsChanged", id => {
                if (id !== requestId) return;

                const container = document.getElementById("comments-container");
                if (!container) return;

                fetch(`/Maintenance/CommentsPartial/${requestId}`)
                    .then(r => r.text())
                            .then(html => {
            container.innerHTML = html;

            // 🔔 Soft chime for new comment
            if (window.sentinelPlayCommentChime) {
                window.sentinelPlayCommentChime();
            }
        })

                    .catch(err => console.error("CommentsPartial load error:", err));
            });

        })();
    </script>

    <script>
        (function () {
            const incidentId = @Model.Id;
            const uiLang     = '@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName';
            const labelGenerated  = '@Html.Raw(SR["AiInsight_Generated"].Value)';
            const labelDemoLimit  = '@Html.Raw(SR["AiInsight_Demo_Limit"].Value)';
            const loading    = document.getElementById("ai-insight-loading");
            const content    = document.getElementById("ai-insight-content");
            const error      = document.getElementById("ai-insight-error");
            const actions    = document.getElementById("ai-insight-actions");
            const timestamp  = document.getElementById("ai-insight-timestamp");
            const refreshBtn = document.getElementById("ai-insight-refresh");
            const retryLink  = document.getElementById("ai-insight-retry");

            function showState(state) {
                loading.classList.toggle("d-none", state !== "loading");
                content.classList.toggle("d-none", state !== "done");
                error.classList.toggle("d-none", state !== "error");
                actions.classList.toggle("d-none", state !== "done");
            }

            async function loadInsight(force) {
                showState("loading");
                refreshBtn.disabled = true;

                try {
                    const url = `/api/ai/insight/incident/${incidentId}?lang=${uiLang}${force ? "&force=true" : ""}`;
                    const resp = await fetch(url);

                    if (resp.status === 429) {
                        content.innerHTML = `<div class="text-warning">⚠️ ${labelDemoLimit}</div>`;
                        showState("done");
                        return;
                    }

                    if (!resp.ok) throw new Error(resp.status);

                    const data = await resp.json();

                    // Escape and convert newlines to <br>
                    const tmp = document.createElement("div");
                    tmp.textContent = data.insightText;
                    const safe = tmp.innerHTML.replace(/\n/g, "<br>");
                    content.innerHTML = safe;

                    if (data.createdUtc) {
                        const dt = new Date(data.createdUtc);
                        timestamp.textContent = `${labelGenerated} ${dt.toLocaleString()}`;
                    }

                    showState("done");
                } catch {
                    showState("error");
                } finally {
                    refreshBtn.disabled = false;
                }
            }

            refreshBtn.addEventListener("click", () => loadInsight(true));
            retryLink.addEventListener("click", e => { e.preventDefault(); loadInsight(false); });

            // Auto-load on page open
            loadInsight(false);
        })();
    </script>
}

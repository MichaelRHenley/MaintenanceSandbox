@model List<MaintenanceSandbox.Models.MaintenanceRequest>
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> SR

@{
    ViewData["Title"] = SR["EM_Dashboard_Title"];
    ViewData["AiModuleKey"] = "EM_Dashboard";

    int activeCount        = ViewBag.ActiveCount        is int ac  ? ac  : 0;
    int machineDownCount   = ViewBag.MachineDownCount   is int md  ? md  : 0;
    int investigatingCount = ViewBag.InvestigatingCount is int inv ? inv : 0;
    int runningCount       = ViewBag.RunningCount       is int run ? run : 0;
    double avgMin          = ViewBag.AvgResponseMinutes is double avg ? avg : 0.0;
    string statusFilter    = ViewBag.StatusFilter as string ?? "All";

    string EmStatusLabel(string? s) => (s ?? "") switch
    {
        "New"              => SR["EM_Status_MachineDown"],
        "In Progress"      => SR["EM_Status_Investigating"],
        "Waiting on Parts" => SR["EM_Status_Investigating"],
        "Resolved"         => SR["EM_Status_Running"],
        _                  => s ?? ""
    };

    string EmStatusClass(string? s) => (s ?? "") switch
    {
        "New"              => "em-status-machine-down",
        "In Progress"      => "em-status-investigating",
        "Waiting on Parts" => "em-status-investigating",
        "Resolved"         => "em-status-running",
        _                  => "em-status-completed"
    };

    string EmCardClass(string? s) => (s ?? "") switch
    {
        "New"              => "em-card-machine-down",
        "In Progress"      => "em-card-investigating",
        "Waiting on Parts" => "em-card-investigating",
        "Resolved"         => "em-card-running",
        _                  => "em-card-completed"
    };

    string EmStatusIcon(string? s) => (s ?? "") switch
    {
        "New"              => "🔴",
        "In Progress"      => "🟡",
        "Waiting on Parts" => "🟡",
        "Resolved"         => "🟢",
        _                  => "⚪"
    };
}

<div class="container-fluid py-4">

    <!-- Live update banner -->
    <div id="em-updates-banner" class="sentinel-update-banner">
        <span>@SR["EM_Dashboard_UpdateBanner"]</span>&nbsp;
        <small>@SR["Maint_Index_UpdatesBanner_Click"]</small>
    </div>

    <div class="sentinel-card">

        <!-- Header -->
        <div class="sentinel-page-header">
            <div>
                <div class="sentinel-page-title">@SR["EM_Dashboard_Title"]</div>
                <div class="sentinel-page-subtitle">
                    @SR["App_Title"] · @SR["EM_Dashboard_Subtitle"]
                </div>
                <div class="sentinel-page-meta small text-muted mt-1"
                     id="last-updated"
                     data-label-prefix="@SR["Maint_Index_LastUpdated_Label"]"
                     data-label-justnow="@SR["Maint_Index_LastUpdated_JustNow"]">
                    @SR["Maint_Index_LastUpdated_Label"] @DateTime.Now.ToString("T", CultureInfo.CurrentUICulture)
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                @await Html.PartialAsync("_AiHelpLauncher")
                <span id="live-indicator"
                      class="sentinel-live-indicator sentinel-live-indicator--offline">
                    <span class="dot"></span>
                    <span class="label">@SR["LiveIndicator_Label_Connecting"]</span>
                </span>
                <a asp-action="Create" class="btn btn-sm btn-sentinel-primary">
                    @SR["Maint_Index_Button_NewRequest"]
                </a>
            </div>
        </div>

        <!-- KPI Summary Bar — horizontally scrollable on mobile -->
        <div id="em-kpis" class="em-kpi-bar">
            <div class="em-kpi-scroll">
                <div class="sentinel-kpi-tile text-center">
                    <div class="sentinel-kpi-label">@SR["EM_Dashboard_KPI_Active"]</div>
                    <div class="sentinel-kpi-value" id="kpi-active">@activeCount</div>
                </div>
                <div class="sentinel-kpi-tile text-center em-kpi-tile--down">
                    <div class="sentinel-kpi-label">@SR["EM_Dashboard_KPI_MachineDown"]</div>
                    <div class="sentinel-kpi-value em-kpi-value--down" id="kpi-machinedown">@machineDownCount</div>
                </div>
                <div class="sentinel-kpi-tile text-center em-kpi-tile--inv">
                    <div class="sentinel-kpi-label">@SR["EM_Dashboard_KPI_Investigating"]</div>
                    <div class="sentinel-kpi-value em-kpi-value--inv" id="kpi-investigating">@investigatingCount</div>
                </div>
                <div class="sentinel-kpi-tile text-center em-kpi-tile--run">
                    <div class="sentinel-kpi-label">@SR["EM_Dashboard_KPI_Running"]</div>
                    <div class="sentinel-kpi-value em-kpi-value--run" id="kpi-running">@runningCount</div>
                </div>
                <div class="sentinel-kpi-tile text-center">
                    <div class="sentinel-kpi-label">@SR["EM_Dashboard_KPI_AvgResponse"]</div>
                    <div class="sentinel-kpi-value">
                        @avgMin <small class="text-muted" style="font-size:0.75rem;">@SR["EM_Dashboard_Min"]</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Filter Tabs -->
        <div class="px-3 pt-2 pb-3 border-top border-secondary d-flex flex-wrap gap-2 align-items-center">
            @{
                var tabs = new (string Key, string Label, int? Count)[]
                {
                    ("All",           SR["EM_Dashboard_Filter_All"],           null),
                    ("Machine Down",  SR["EM_Dashboard_Filter_MachineDown"],   machineDownCount > 0   ? machineDownCount   : (int?)null),
                    ("Investigating", SR["EM_Dashboard_Filter_Investigating"], investigatingCount > 0 ? investigatingCount : (int?)null),
                    ("Running",       SR["EM_Dashboard_Filter_Running"],       runningCount > 0       ? runningCount       : (int?)null),
                };

                foreach (var (key, label, count) in tabs)
                {
                    var isActive = key == statusFilter;
                    var slug = key.ToLower().Replace(" ", "-");
                    var href = Url.Action("EmDashboard", "Maintenance", new { statusFilter = key == "All" ? null : (object)key });
                    <a href="@href" class="em-filter-tab @(isActive ? "active" : "") em-filter-tab--@slug">
                        @label
                        @if (count.HasValue)
                        {
                            <span class="em-filter-count">@count</span>
                        }
                    </a>
                }
            }
        </div>

        <!-- Card Grid -->
        <div id="em-dashboard-grid" class="px-3 px-md-4 pb-4">

            @if (!Model.Any())
            {
                <div class="text-center mt-5 mb-4">
                    <div style="font-size:2.5rem; line-height:1;">🟢</div>
                    <p class="fs-5 fw-semibold mt-3 mb-1">@SR["EM_Dashboard_AllClear"]</p>
                    <p class="text-muted small">@SR["EM_Dashboard_NoRequests"]</p>
                </div>
            }
            else
            {
                <div class="row g-3 mt-1">
                    @foreach (var r in Model)
                    {
                        var latestOpsMsg = r.Messages
                            .Where(m => string.Equals(m.Sender, "Operator", StringComparison.OrdinalIgnoreCase)
                                     || string.Equals(m.Sender, "Operations", StringComparison.OrdinalIgnoreCase))
                            .OrderByDescending(m => m.SentAt)
                            .FirstOrDefault();

                        var latestMaintMsg = r.Messages
                            .Where(m => string.Equals(m.Sender, "Technician", StringComparison.OrdinalIgnoreCase)
                                     || string.Equals(m.Sender, "Tech", StringComparison.OrdinalIgnoreCase)
                                     || string.Equals(m.Sender, "Maintenance", StringComparison.OrdinalIgnoreCase))
                            .OrderByDescending(m => m.SentAt)
                            .FirstOrDefault();

                        var latestMsg    = r.Messages.OrderByDescending(m => m.SentAt).FirstOrDefault();
                        var createdLocal = r.CreatedAt.ToLocalTime();
                        var createdIso   = r.CreatedAt.ToString("o");

                        <div class="col-12 col-md-6 col-xl-4">
                            <div class="em-card maintenance-card ready @EmCardClass(r.Status) h-100 d-flex flex-column p-3"
                                 data-request-id="@r.Id"
                                 data-created-utc="@createdIso">

                                <!-- Equipment + status badge -->
                                <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                    <div class="flex-grow-1" style="min-width:0;">
                                        <div class="fw-bold text-truncate" style="font-size:1rem;">
                                            @(r.Equipment?.DisplayName ?? r.Equipment?.Code ?? SR["EM_Dashboard_Label_NoEquipment"].Value)
                                        </div>
                                        <div class="small text-muted">
                                            @(r.WorkCenter?.Code ?? "-") · @r.Site
                                        </div>
                                    </div>
                                    <span class="em-status-badge @EmStatusClass(r.Status) flex-shrink-0">
                                        @EmStatusIcon(r.Status) @EmStatusLabel(r.Status)
                                    </span>
                                </div>

                                <!-- Opened time + downtime timer -->
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted">
                                        @SR["EM_Dashboard_Label_Opened"]:
                                        <strong class="text-light">@createdLocal.ToString("t", CultureInfo.CurrentUICulture)</strong>
                                    </span>
                                    @if (r.Status != "Resolved")
                                    {
                                        <span class="em-downtime-timer" data-created-utc="@createdIso">
                                            ⏱ <span class="em-timer-digits">--:--:--</span>
                                        </span>
                                    }
                                </div>

                                <!-- Response time / no-response indicator -->
                                @{
                                    var responseMinutes = r.RespondedAt.HasValue
                                        ? (r.RespondedAt.Value - r.CreatedAt).TotalMinutes
                                        : (double?)null;
                                    var minutesSinceOpen = (DateTime.UtcNow - r.CreatedAt).TotalMinutes;
                                }
                                @if (responseMinutes.HasValue)
                                {
                                    <div class="em-response-row mb-2">
                                        ⚡ @SR["EM_Dashboard_Label_ResponseTime"]:
                                        <span class="em-response-time fw-medium">@Math.Round(responseMinutes.Value, 1) @SR["EM_Dashboard_Min"]</span>
                                    </div>
                                }
                                else if (r.Status == "New")
                                {
                                    <div class="em-response-row mb-2">
                                        @if (minutesSinceOpen > 15)
                                        {
                                            <span class="em-no-response em-no-response--urgent">⚠ @SR["EM_Dashboard_Label_NoResponse"]</span>
                                        }
                                        else if (minutesSinceOpen > 5)
                                        {
                                            <span class="em-no-response em-no-response--warning">@SR["EM_Dashboard_Label_NoResponse"]</span>
                                        }
                                        else
                                        {
                                            <span class="em-no-response">@SR["EM_Dashboard_Label_AwaitingResponse"]</span>
                                        }
                                    </div>
                                }

                                <!-- Issue description -->
                                <div class="em-field-block mb-2">
                                    <div class="em-field-label">@SR["EM_Dashboard_Label_Issue"]</div>
                                    <div class="em-field-value text-break">@r.Description</div>
                                </div>

                                <!-- Latest ops comment -->
                                @if (latestOpsMsg is not null)
                                {
                                    <div class="em-field-block mb-2">
                                        <div class="em-field-label">@SR["EM_Dashboard_Label_OpsComment"]</div>
                                        <div class="em-field-value text-break fst-italic">@latestOpsMsg.Message</div>
                                    </div>
                                }

                                <!-- Latest maintenance comment -->
                                @if (latestMaintMsg is not null)
                                {
                                    <div class="em-field-block mb-2">
                                        <div class="em-field-label">@SR["EM_Dashboard_Label_MaintComment"]</div>
                                        <div class="em-field-value text-break fst-italic">@latestMaintMsg.Message</div>
                                    </div>
                                }

                                <!-- Footer: responder + last update + open button -->
                                <div class="mt-auto pt-2 border-top border-secondary-subtle d-flex justify-content-between align-items-end gap-2">
                                    <div class="small text-muted lh-sm">
                                        <div>
                                            @SR["EM_Dashboard_Label_Responder"]:
                                            <span class="text-light fw-medium">@(r.ResolvedBy ?? r.RequestedBy)</span>
                                        </div>
                                        @if (latestMsg is not null)
                                        {
                                            <div>
                                                @SR["EM_Dashboard_Label_LastUpdate"]:
                                                <span class="text-light">@latestMsg.SentAt.ToLocalTime().ToString("t", CultureInfo.CurrentUICulture)</span>
                                            </div>
                                        }
                                    </div>
                                    <a asp-action="Details" asp-route-id="@r.Id"
                                       class="btn btn-sm btn-sentinel-ghost flex-shrink-0">
                                        @SR["EM_Dashboard_Button_Open"]
                                    </a>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        if (!window.signalR) return;

        // ── Downtime timers ──────────────────────────────────────────────
        function formatDuration(ms) {
            const totalSec = Math.floor(ms / 1000);
            const h = Math.floor(totalSec / 3600);
            const m = Math.floor((totalSec % 3600) / 60);
            const s = totalSec % 60;
            return [h, m, s].map(v => String(v).padStart(2, '0')).join(':');
        }

        function tickTimers() {
            const now = Date.now();
            document.querySelectorAll('.em-downtime-timer[data-created-utc]').forEach(el => {
                const created = new Date(el.dataset.createdUtc).getTime();
                const digits = el.querySelector('.em-timer-digits');
                if (digits) digits.textContent = formatDuration(now - created);
            });
        }

        tickTimers();
        setInterval(tickTimers, 1000);

        // ── Last updated stamp ───────────────────────────────────────────
        function updateLastUpdatedStamp() {
            const el = document.getElementById('last-updated');
            if (!el) return;
            const prefix = el.dataset.labelPrefix || 'Last updated:';
            el.textContent = prefix + ' ' + new Date().toLocaleTimeString();
            el.classList.add('updated-pulse');
            setTimeout(() => el.classList.remove('updated-pulse'), 700);
        }

        // ── SignalR ──────────────────────────────────────────────────────
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/maintenance')
            .withAutomaticReconnect()
            .build();

        let reloadTimer = null;

        connection.on('MaintenanceListChanged', function () {
            updateLastUpdatedStamp();

            if (window.sentinelPlaySound)
                window.sentinelPlaySound('siren');

            // debounced auto-reload so rapid events batch into one refresh
            clearTimeout(reloadTimer);
            reloadTimer = setTimeout(() => window.location.reload(), 1500);
        });

        connection.onreconnecting(() => {
            if (window.sentinelUpdateLiveIndicator)
                window.sentinelUpdateLiveIndicator('reconnecting');
        });

        connection.onreconnected(() => {
            if (window.sentinelUpdateLiveIndicator)
                window.sentinelUpdateLiveIndicator('ok');
        });

        connection.onclose(() => {
            if (window.sentinelUpdateLiveIndicator)
                window.sentinelUpdateLiveIndicator('offline');
        });

        connection.start()
            .then(() => {
                if (window.sentinelUpdateLiveIndicator)
                    window.sentinelUpdateLiveIndicator('ok', { suppressToast: true });
            })
            .catch(err => console.error('SignalR EM Dashboard error:', err));

    })();
    </script>
}

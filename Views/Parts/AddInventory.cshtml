@model MaintenanceSandbox.Models.Parts.AddInventoryViewModel

@{
    ViewData["Title"] = $"Add Inventory – {Model.PartNumber}";
    ViewData["AiModuleKey"] = "Inventory_Add";
}

<div class="container py-4">
    <div class="mb-3">
        <a asp-action="Details" asp-route-id="@Model.PartId" class="btn btn-sm btn-outline-light">
            ← Back to Part
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h4 mb-0">Add Inventory for @Model.PartNumber</h1>

                <div class="d-flex align-items-center gap-2">
                    @await Html.PartialAsync("_AiHelpLauncher")
                </div>
            </div>

            <form asp-action="AddInventory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PartId" />

                <div class="mb-3">
                    <label asp-for="LocationBinId" class="form-label"></label>
                    <select asp-for="LocationBinId"
                            asp-items="Model.LocationOptions"
                            class="form-select">
                        <option value="">-- Select location/bin --</option>
                    </select>
                    <span asp-validation-for="LocationBinId" class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="QuantityOnHand" class="form-label"></label>
                        <input asp-for="QuantityOnHand" class="form-control" />
                        <span asp-validation-for="QuantityOnHand" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ReorderPoint" class="form-label"></label>
                        <input asp-for="ReorderPoint" class="form-control" />
                        <span asp-validation-for="ReorderPoint" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TargetQuantity" class="form-label"></label>
                        <input asp-for="TargetQuantity" class="form-control" />
                        <span asp-validation-for="TargetQuantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <a asp-action="Details" asp-route-id="@Model.PartId"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        Save Inventory
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


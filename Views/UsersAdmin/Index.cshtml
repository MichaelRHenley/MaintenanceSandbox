@model List<MaintenanceSandbox.ViewModels.Admin.UserRowVm>
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR

@{
    ViewData["Title"] = "User Admin";
}

<div class="container py-4">
    <div class="sentinel-card">
        <div class="sentinel-page-header">
            <div>
                <div class="sentinel-page-title">User Admin</div>
                <div class="sentinel-page-subtitle">@SR["App_Title"] · Settings</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-sentinel-primary btn-sm" asp-action="Create">Add User</a>
                <a class="btn btn-sentinel-ghost btn-sm" asp-controller="Settings" asp-action="Index">Back</a>
            </div>
        </div>

        <div class="p-3 p-md-4">
            @if (TempData["ok"] is string ok)
            {
                <div class="alert alert-success">@ok</div>
            }

            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>@u.Email</td>
                                <td>@u.DisplayName</td>
                                <td>@u.Roles</td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (u.IsActive)
                                    {
                                        <form asp-action="Deactivate" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.UserId" />
                                            <button class="btn btn-sm btn-outline-warning" type="submit">Deactivate</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reactivate" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.UserId" />
                                            <button class="btn btn-sm btn-outline-info" type="submit">Reactivate</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

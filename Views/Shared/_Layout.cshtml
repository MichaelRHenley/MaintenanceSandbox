@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SR
@using MaintenanceSandbox.Services
@inject ITierProvider TierProvider
@using Microsoft.AspNetCore.Localization
@inject Microsoft.Extensions.Configuration.IConfiguration Config


@functions {
    string IsActive(string controller, string action)
    {
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        return (string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
             && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            ? "active"
            : string.Empty;
    }
}

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var htmlLang = requestCulture?.RequestCulture.UICulture.Name ?? "en";

    // Tier text via SR
    var tierEnum = TierProvider.CurrentTier;
    var tierClass = tierEnum switch
    {
        ProductTier.Enhanced => "sentinel-tier-pill--enhanced",
        ProductTier.Premium => "sentinel-tier-pill--premium",
        _ => "sentinel-tier-pill--standard"
    };

    string tierLabelKey = tierEnum switch
    {
        ProductTier.Enhanced => "Tier_Label_Enhanced",
        ProductTier.Premium => "Tier_Label_Premium",
        _ => "Tier_Label_Standard"
    };

    var tierText = SR[tierLabelKey];
    var tierSuffix = SR["Tier_Label_TierSuffix"];

    var ga4Id = Config["Analytics:GA4MeasurementId"] ?? "";
    var clarityId = Config["Analytics:ClarityProjectId"] ?? "";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var analyticsRole = isAuthenticated
        ? (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")
        : "anonymous";
    var analyticsIsDemo = isAuthenticated && User.HasClaim("is_demo", "true");
    var demoSmsExpiry = Config["Demo:EmailLinkExpiryMinutes"] ?? "30";
}

<!DOCTYPE html>
<html lang="@htmlLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @SR["App_Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MaintenanceSandbox.styles.css" asp-append-version="true" />
    @if (!string.IsNullOrEmpty(ga4Id))
    {
        <!-- Google tag (gtag.js) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=@ga4Id"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@ga4Id');
        </script>
    }
    @if (!string.IsNullOrEmpty(clarityId))
    {
        <!-- Microsoft Clarity -->
        <script>
            (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window, document, "clarity", "script", "@clarityId");
            clarity('set', 'user_role', '@analyticsRole');
            clarity('set', 'is_demo',   '@analyticsIsDemo.ToString().ToLower()');
            clarity('set', 'tier',      '@tierEnum.ToString()');
        </script>
    }
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sentinel-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    @SR["App_Title"]
                    <span>Sentinel</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon">
                        <span></span>
                    </span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Home", "Index")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                @SR["Nav_Home"]
                            </a>
                        </li>
                        @if (User.IsInRole("Supervisor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Maintenance", "EmDashboard")"
                                       asp-area="" asp-controller="Maintenance" asp-action="EmDashboard">
                                    @SR["Nav_EmDashboard"]
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Maintenance", "Index")"
                               asp-area="" asp-controller="Maintenance" asp-action="Index">
                                @SR["Nav_Maintenance"]
                            </a>
                        </li>
                       
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Settings", "Index")"
                               asp-area="" asp-controller="Settings" asp-action="Index">
                                @SR["Nav_Settings"]
                            </a>
                        </li>
                        @await Component.InvokeAsync("OnboardingNav")
                    </ul>

                    <div class="d-flex align-items-center gap-3">

                        <!-- Tier badge -->
                        <div class="sentinel-tier-pill @tierClass">
                            <span>@tierText</span>
                            <small>@tierSuffix</small>
                        </div>

                        <!-- 🔔 Sound toggle -->
                        <button type="button"
                                id="sound-toggle-btn"
                                class="sentinel-sound-btn"
                                data-text-on="@SR["Nav_SoundOn"]"
                                data-text-off="@SR["Nav_SoundOff"]">
                            🔊 @SR["Nav_SoundOn"]
                        </button>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            var roleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
                            var isDemo = User.HasClaim("is_demo", "true");

                            string? roleKey = roleClaim switch
                            {
                                "Supervisor" => "Role_Supervisor",
                                "Operator" => "Role_Operator",
                                "MaintenanceManager" => "Role_MaintenanceManager",
                                "Manager" => "Role_MaintenanceManager",
                                _ => null
                            };

                            var localizedRole = roleKey is null ? roleClaim : SR[roleKey];

                            @if (isDemo)
                            {
                                <div class="sentinel-user-pill d-flex align-items-center gap-2">
                                    <span class="sentinel-role-badge">Demo</span>
                                    <form asp-controller="DemoUser" asp-action="SwitchRole" method="post" class="d-flex gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" name="role" value="Supervisor"
                                                class="sentinel-signout-btn @(roleClaim == "Supervisor" ? "active" : "")">
                                            Supervisor
                                        </button>
                                        <button type="submit" name="role" value="Operator"
                                                class="sentinel-signout-btn @(roleClaim == "Operator" ? "active" : "")">
                                                    Operator
                                                </button>
                                        <button type="submit" name="role" value="Tech"
                                                class="sentinel-signout-btn @(roleClaim == "Tech" ? "active" : "")">
                                                    Tech
                                                </button>
                                                    </form>
                                    <button type="button"
                                            class="sentinel-signout-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#demo-share-modal">📧 Share</button>
                                </div>
                            }
                            else
                            {
                                <div class="sentinel-user-pill d-flex align-items-center gap-2">
                                    <span class="sentinel-user-name">@User.Identity!.Name</span>
                                    <span class="sentinel-role-badge">@localizedRole</span>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="sentinel-signout-btn">Sign out</button>
                                    </form>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sentinel-user-pill">
                                <a href="/Account/Login" class="sentinel-signout-btn">Sign in</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between align-items-center">
            <span>
                &copy; 2025 - Sentinel AI Systems -
                <a asp-area="" asp-controller="Home" asp-action="Privacy">
                    @SR["Nav_Privacy"]
                </a>
            </span>

            <span id="global-live-indicator"
                  class="sentinel-live-indicator sentinel-live-indicator--offline"
                  data-label-live="@SR["LiveIndicator_Label_Live"]"
                  data-label-reconnecting="@SR["LiveIndicator_Label_Reconnecting"]"
                  data-label-offline="@SR["LiveIndicator_Label_Offline"]"
                  data-toast-reconnected="@SR["Toast_Reconnected"]"
                  data-toast-reconnecting="@SR["Toast_Reconnecting"]"
                  data-toast-offline="@SR["Toast_Offline"]">
                <span class="dot"></span>
                <span class="label">@SR["LiveIndicator_Label_Offline"]</span>
            </span>
        </div>
    </footer>

    <audio id="maintenance-alert-sound"
           src="~/sounds/alarm-siren-sound-effect-type-01-294194.mp3"
           preload="auto">
    </audio>

    <audio id="maintenance-comment-sound"
           src="~/sounds/chime-alert.mp3"
           preload="auto">
    </audio>

    

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        (function () {
            const STORAGE_KEY = "sentinel.maintenance.sound.enabled";

            function getSoundEnabled() {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (raw === null) return true; // default: ON
                return raw === "true";
            }

            function setSoundEnabled(value) {
                localStorage.setItem(STORAGE_KEY, value ? "true" : "false");
            }

                    function updateSoundToggleUi() {
            const btn = document.getElementById("sound-toggle-btn");
            if (!btn) return;

            const enabled = getSoundEnabled();
            btn.dataset.enabled = enabled ? "true" : "false";

            const onText = btn.dataset.textOn || "Sound on";
            const offText = btn.dataset.textOff || "Sound off";

            btn.textContent = enabled ? `🔊 ${onText}` : `🔈 ${offText}`;
            btn.classList.toggle("btn-outline-light", enabled);
            btn.classList.toggle("btn-outline-secondary", !enabled);
        }


            document.addEventListener("DOMContentLoaded", function () {
                updateSoundToggleUi();

                const btn = document.getElementById("sound-toggle-btn");
                if (!btn) return;

                btn.addEventListener("click", function () {
                    const current = getSoundEnabled();
                    setSoundEnabled(!current);
                    updateSoundToggleUi();
                    if (window.sentinelTrack) window.sentinelTrack('sound_toggled', { enabled: !current });
                });
            });

            window.sentinelSoundEnabled = function () {
                return getSoundEnabled();
            };

            window.sentinelHapticAlert = function () {
                if (!getSoundEnabled()) return;
                if (!("vibrate" in navigator)) return;

                try {
                    navigator.vibrate([120, 60, 120]);
                } catch (e) {
                    console.warn("Vibration not available or blocked:", e);
                }
            };
                    // 🔊 Notification engine: separate sounds + cooldown
        const NOTIFY_COOLDOWN_MS = 8000; // 8 seconds
        let lastEmAlertTs = 0;
        let lastCommentChimeTs = 0;

        function playWithCooldown(audioElementId, isEmAlert) {
            // Respect global sound toggle
            if (!getSoundEnabled()) return;

            const now = Date.now();

            if (isEmAlert) {
                if (now - lastEmAlertTs < NOTIFY_COOLDOWN_MS) return;
                lastEmAlertTs = now;
            } else {
                if (now - lastCommentChimeTs < NOTIFY_COOLDOWN_MS) return;
                lastCommentChimeTs = now;
            }

            const audio = document.getElementById(audioElementId);
            if (!audio) return;

            try {
                audio.currentTime = 0;
                audio.play().catch(err => {
                    console.warn("Audio play blocked:", err);
                });
            } catch (err) {
                console.warn("Audio playback error:", err);
            }

            // Optional haptics
            if (window.sentinelHapticAlert) {
                window.sentinelHapticAlert();
            }
        }

        // 🌟 Public helpers for pages to call
        window.sentinelPlayNewEmAlert = function () {
            playWithCooldown("maintenance-alert-sound", true);
        };

        window.sentinelPlayCommentChime = function () {
            playWithCooldown("maintenance-comment-sound", false);
        };

        // 📊 Analytics helper — fires to GA4 + Clarity simultaneously
        window.sentinelTrack = function (eventName, params) {
            if (typeof gtag === 'function') {
                gtag('event', eventName, params || {});
            }
            if (typeof clarity !== 'undefined') {
                clarity('event', eventName);
            }
        };


            function showToast(message, kind) {
                const el = document.getElementById("sentinel-toast");
                if (!el || !message) return;

                el.className = "sentinel-toast";
                if (kind) {
                    el.classList.add("sentinel-toast--" + kind);
                }

                el.textContent = message;
                el.classList.add("show");

                clearTimeout(el._hideTimer);
                el._hideTimer = setTimeout(() => {
                    el.classList.remove("show");
                }, 4000);
            }

                   let lastState = null; // "ok", "reconnecting", "offline"

        window.sentinelUpdateLiveIndicator = function (state, options) {
            const local  = document.getElementById("live-indicator");
            const global = document.getElementById("global-live-indicator");
            const targets = [local, global].filter(Boolean);
            if (!targets.length) return;

            const raw = (state || "").toLowerCase();
            let normalized;
            if (raw === "ok" || raw === "live" || raw === "online") {
                normalized = "ok";
            } else if (raw === "reconnecting" || raw === "connecting") {
                normalized = "reconnecting";
            } else {
                normalized = "offline";
            }

            // Grab localized labels & messages from data attributes
            const g = global;
            const labelLive         = g?.dataset.labelLive         || "Live";
            const labelReconnecting = g?.dataset.labelReconnecting || "Reconnecting…";
            const labelOffline      = g?.dataset.labelOffline      || "Offline";
            const toastReconnected  = g?.dataset.toastReconnected  || "Reconnected to live updates.";
            const toastReconnecting = g?.dataset.toastReconnecting || "Connection disrupted. Attempting to reconnect…";
            const toastOffline      = g?.dataset.toastOffline      || "Live updates are offline. Changes may not appear in real time.";

            targets.forEach(el => {
                el.classList.remove(
                    "sentinel-live-indicator--ok",
                    "sentinel-live-indicator--reconnecting",
                    "sentinel-live-indicator--offline"
                );

                const label = el.querySelector(".label");

                switch (normalized) {
                    case "ok":
                        el.classList.add("sentinel-live-indicator--ok");
                        if (label) label.textContent = labelLive;
                        break;
                    case "reconnecting":
                        el.classList.add("sentinel-live-indicator--reconnecting");
                        if (label) label.textContent = labelReconnecting;
                        break;
                    case "offline":
                    default:
                        el.classList.add("sentinel-live-indicator--offline");
                        if (label) label.textContent = labelOffline;
                        break;
                }
            });

            const suppressToast = options && options.suppressToast;
            if (!suppressToast && lastState && lastState !== normalized) {
                if (normalized === "ok") {
                    showToast(toastReconnected, "success");
                } else if (normalized === "reconnecting") {
                    showToast(toastReconnecting, "warning");
                } else if (normalized === "offline") {
                    showToast(toastOffline, "error");
                }
            }

            lastState = normalized;
        };
        })();
    </script>

    @if (analyticsIsDemo)
    {
        <!-- Demo email share modal — only rendered for active demo sessions -->
        <div class="modal fade" id="demo-share-modal" tabindex="-1"
             aria-labelledby="demo-share-label" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-white border border-secondary">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title" id="demo-share-label">📧 Share Demo Access</h5>
                        <button type="button" class="btn-close btn-close-white"
                                data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-3">
                            Send a one-time login link so someone else can join
                            <strong>this exact demo session</strong>.
                            Link expires in @demoSmsExpiry minutes.
                        </p>
                        <form id="demo-share-form" autocomplete="off">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label">Email address</label>
                                <input type="email" name="toEmail"
                                       class="form-control bg-dark text-white border-secondary"
                                       placeholder="colleague@example.com" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Role</label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="role" value="Supervisor" id="share-role-sup" />
                                        <label class="form-check-label" for="share-role-sup">Supervisor</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="role" value="Operator" id="share-role-op" checked />
                                        <label class="form-check-label" for="share-role-op">Operator</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="role" value="Tech" id="share-role-tech" />
                                        <label class="form-check-label" for="share-role-tech">Tech</label>
                                    </div>
                                </div>
                            </div>
                            <button type="submit" id="demo-share-submit"
                                    class="btn btn-sentinel-primary w-100">Send Link</button>
                        </form>
                        <div id="demo-share-result" class="mt-3" style="display:none;"></div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            (function () {
                const form = document.getElementById('demo-share-form');
                if (!form) return;

                form.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    const btn = document.getElementById('demo-share-submit');
                    const result = document.getElementById('demo-share-result');

                    btn.disabled = true;
                    btn.textContent = 'Sending\u2026';
                    result.style.display = 'none';

                    try {
                        const resp = await fetch('/DemoUser/SendEmailLink', {
                            method: 'POST',
                            body: new FormData(form)
                        });
                        const data = await resp.json();

                        result.style.display = 'block';
                        if (data.error) {
                            result.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
                        } else if (data.emailSent) {
                            result.innerHTML = `<div class="alert alert-success">\u2705 Email sent! Link expires in @demoSmsExpiry minutes.</div>`;
                            form.reset();
                        } else {
                            const link = data.link || '';
                            const escaped = link.replace(/'/g, "\\'");
                            result.innerHTML = `
                                <div class="alert alert-warning">
                                    <strong>Email not configured.</strong> Share this link manually:
                                    <div class="mt-2 text-break small"><a href="${link}" target="_blank">${link}</a></div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
                                            onclick="navigator.clipboard.writeText('${escaped}').then(()=>this.textContent='\u2705 Copied!')">
                                        \uD83D\uDCCB Copy link
                                    </button>
                                </div>`;
                        }
                    } catch {
                        result.style.display = 'block';
                        result.innerHTML = `<div class="alert alert-danger">Request failed. Please try again.</div>`;
                    } finally {
                        btn.disabled = false;
                        btn.textContent = 'Send Link';
                    }
                });
            })();
        </script>
    }

    @RenderSection("Scripts", required: false)
    <div id="sentinel-toast" class="sentinel-toast"></div>

</body>
</html>

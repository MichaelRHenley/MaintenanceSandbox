@model MaintenanceSandbox.Models.Production.ProductionIndexVm

@{
    ViewData["Title"] = "Production Tracking";
    var efficiency = (Model.TargetCount <= 0) ? 0 : (int)Math.Round((double)Model.CurrentCount / Model.TargetCount * 100);
    efficiency = Math.Clamp(efficiency, 0, 100);
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="sentinel-card mb-4">
        <div class="sentinel-page-header">
            <div>
                <div class="sentinel-page-title">Production Tracking</div>
                <div class="sentinel-page-subtitle">Operations · Real-Time Data Entry</div>
                <div class="small text-muted mt-1" id="last-updated">
                    Last updated: <span id="update-time">--:--:--</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="shift-indicator">
                    <span class="shift-dot"></span>
                    <span>SHIFT 1 · 06:00-14:00</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">

        <!-- LEFT -->
        <div class="col-lg-4">
            <div class="sentinel-card mb-3">
                <div class="p-3">
                    <h6 class="text-uppercase text-muted mb-3" style="font-size:.75rem; letter-spacing:.06em;">
                        Work Center Selection
                    </h6>

                    <form method="get" asp-controller="Production" asp-action="Index" id="filtersForm">
                        <div class="mb-3">
                            <label class="form-label small">Site</label>
                            <select id="siteSelect"
                                    name="selectedSite"
                                    class="form-select form-control-production"
                                    asp-items="Model.Sites"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Area</label>
                            <select id="areaSelect"
                                    name="selectedArea"
                                    class="form-select form-control-production"
                                    asp-items="Model.Areas"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Work Center</label>
                            <select id="workCenterSelect"
                                    name="selectedWorkCenter"
                                    class="form-select form-control-production"
                                    asp-items="Model.WorkCenters"></select>
                        </div>

                        <div>
                            <label class="form-label small">Equipment</label>
                            <select id="equipmentSelect"
                                    name="selectedEquipment"
                                    class="form-select form-control-production"
                                    asp-items="Model.Equipment"></select>
                        </div>
                    </form>
                </div>
            </div>

            <div class="sentinel-card">
                <div class="p-3">
                    <h6 class="text-uppercase text-muted mb-3" style="font-size:.75rem; letter-spacing:.06em;">
                        Current Status
                    </h6>

                    <div class="production-status-card mb-2">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="small text-muted">Production Count</div>
                            <div class="small text-success">● Running</div>
                        </div>

                        <div class="count-display" id="currentCount">@Model.CurrentCount</div>
                        <div class="target-display">Target: @Model.TargetCount.ToString("N0") units</div>

                        <div class="efficiency-bar">
                            <div class="efficiency-fill" id="efficiencyBar" style="width:@efficiency%"></div>
                        </div>

                        <div class="stats-mini mt-3">
                            <div class="stat-mini-item">
                                <div class="stat-mini-label">Scrap</div>
                                <div class="stat-mini-value text-warning">@Model.ScrapCount</div>
                            </div>
                            <div class="stat-mini-item">
                                <div class="stat-mini-label">Downtime</div>
                                <div class="stat-mini-value text-danger">@Model.DowntimeMinutes m</div>
                            </div>
                            <div class="stat-mini-item">
                                <div class="stat-mini-label">OEE</div>
                                <div class="stat-mini-value text-info">@Model.Oee%</div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info mb-0 mt-3"
                         style="background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.3); color: var(--sentinel-text);">
                        <small><strong>Tier 1 Mode:</strong> Manual entry stored in Sentinel SQL only.</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- CENTER -->
        <div class="col-lg-4">
            <div class="sentinel-card">
                <div class="p-3">
                    <h6 class="text-uppercase text-muted mb-3" style="font-size:.75rem; letter-spacing:.06em;">
                        Quick Actions
                    </h6>

                    <div class="quick-action-btn mb-3 text-center" data-bs-toggle="modal" data-bs-target="#productionModal">
                        <div class="quick-action-icon text-success">📦</div>
                        <div class="fw-bold">Log Production Count</div>
                        <div class="small text-muted">Record units produced</div>
                    </div>

                    <div class="quick-action-btn mb-3 text-center" data-bs-toggle="modal" data-bs-target="#downtimeModal">
                        <div class="quick-action-icon text-danger">⏸</div>
                        <div class="fw-bold">Record Downtime</div>
                        <div class="small text-muted">Log equipment stoppage</div>
                    </div>

                    <div class="quick-action-btn mb-3 text-center" data-bs-toggle="modal" data-bs-target="#scrapModal">
                        <div class="quick-action-icon text-warning">⚠️</div>
                        <div class="fw-bold">Report Scrap</div>
                        <div class="small text-muted">Document defective units</div>
                    </div>

                    <div class="quick-action-btn text-center" data-bs-toggle="modal" data-bs-target="#commentModal">
                        <div class="quick-action-icon" style="color: var(--sentinel-accent);">💬</div>
                        <div class="fw-bold">Add Comment</div>
                        <div class="small text-muted">Note observations</div>
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">
            <div class="sentinel-card">
                <div class="p-3">
                    <h6 class="text-uppercase text-muted mb-3" style="font-size:.75rem; letter-spacing:.06em;">
                        Today's Activity
                    </h6>

                    <div class="timeline" style="max-height: 600px; overflow-y: auto;">
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="small text-muted mb-1">06:00 AM · System</div>
                            <div class="small fw-bold">Shift Started</div>
                            <div class="small text-muted">Shift 1 commenced</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<!-- PRODUCTION MODAL -->
<div class="modal fade modal-sentinel" id="productionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-sentinel">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title">Log Production Count</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="LogProduction" method="post" id="productionForm">
                @Html.AntiForgeryToken()

                <input type="hidden" name="selectedSite" id="postSelectedSite" value="@Model.SelectedSite" />
                <input type="hidden" name="selectedArea" id="postSelectedArea" value="@Model.SelectedArea" />
                <input type="hidden" name="selectedWorkCenter" id="postSelectedWorkCenter" value="@Model.SelectedWorkCenter" />
                <input type="hidden" name="selectedEquipment" id="postSelectedEquipment" value="@Model.SelectedEquipment" />

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Units Produced</label>
                        <input type="number"
                               class="form-control form-control-production number-input-large"
                               name="units" value="50" min="1" required />
                        <small class="text-muted">Enter the number of good units produced</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Time Period</label>
                        <select class="form-select form-control-production" name="timePeriod">
                            <option>Last Hour</option>
                            <option>Last 30 Minutes</option>
                            <option selected>Current Time</option>
                            <option>Custom Time</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Comments (Optional)</label>
                        <textarea class="form-control form-control-production" rows="2" name="comments"
                                  placeholder="Any notes about this production run..."></textarea>
                    </div>
                </div>

                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-sentinel-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sentinel-primary">Submit Count</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // Clock
            function updateTime() {
                const el = document.getElementById('update-time');
                if (!el) return;
                el.textContent = new Date().toLocaleTimeString();
            }
            updateTime();
            setInterval(updateTime, 1000);

            // Auto-submit filters
            const filtersForm = document.getElementById('filtersForm');
            ['siteSelect','areaSelect','workCenterSelect','equipmentSelect'].forEach(id => {
                const el = document.getElementById(id);
                if (el && filtersForm) el.addEventListener('change', () => filtersForm.submit());
            });

            // Hidden fields sync for modal POST
            function syncProductionHiddenFields() {
                const site = document.getElementById('siteSelect')?.value ?? "";
                const area = document.getElementById('areaSelect')?.value ?? "";
                const wc   = document.getElementById('workCenterSelect')?.value ?? "";
                const eq   = document.getElementById('equipmentSelect')?.value ?? "";

                document.getElementById('postSite_production').value = site;
                document.getElementById('postArea_production').value = area;
                document.getElementById('postWorkCenter_production').value = wc;
                document.getElementById('postEquipment_production').value = eq;

                console.log("SYNC production", { site, area, wc, eq });
            }

            const modalEl = document.getElementById('productionModal');
            if (modalEl) modalEl.addEventListener('show.bs.modal', syncProductionHiddenFields);

            const prodForm = document.getElementById('productionForm');
            if (prodForm) prodForm.addEventListener('submit', syncProductionHiddenFields);
        });
    </script>

    @if (TempData["ToastSuccess"] is string msg)
    {
        <script>
            alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(msg)));
        </script>
    }
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const prodForm = document.getElementById('productionForm');
          if (!prodForm) return;

          prodForm.addEventListener('submit', () => {
            document.getElementById('postSelectedSite').value = document.getElementById('siteSelect').value;
            document.getElementById('postSelectedArea').value = document.getElementById('areaSelect').value;
            document.getElementById('postSelectedWorkCenter').value = document.getElementById('workCenterSelect').value;
            document.getElementById('postSelectedEquipment').value = document.getElementById('equipmentSelect').value;
          });
        });
    </script>
}

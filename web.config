<?xml version="1.0" encoding="utf-8"?>
<!--
  ASP.NET Core Module v2 (ANCM) configuration.

  This file is TRANSFORMED during publish — the SDK updates the <aspNetCore> element
  automatically. Your custom sections below (requestFiltering, etc.) are preserved.

  TO ENABLE STDOUT LOGGING FOR STARTUP TROUBLESHOOTING (500.30 etc):
    1. Create the .\logs\ folder under the site root on the VM
    2. Grant IIS_IUSRS (or the app pool identity) write access to .\logs\
    3. Set stdoutLogEnabled="true" in this file ON THE SERVER (not in the project)
    4. Recycle the app pool
    5. Reproduce the error, then read .\logs\stdout_*.log
    6. Set stdoutLogEnabled="false" immediately after — stdout logging is unbuffered
       and will degrade performance under load.

  ASPNETCORE_ENVIRONMENT:
    Do NOT set it here — the SDK transform replaces this section.
    Set it as a system environment variable on the VM or via IIS Manager:
      IIS Manager > Site > Configuration Editor >
        system.webServer/aspNetCore > environmentVariables > Add
          Name:  ASPNETCORE_ENVIRONMENT
          Value: Production
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!--
        The SDK replaces this element on publish.
        stdoutLogEnabled defaults to false in Release builds.
        See instructions above to enable temporarily for troubleshooting.
      -->
      <aspNetCore processPath="dotnet"
                  arguments=".\MaintenanceSandbox.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
      <security>
        <requestFiltering>
          <!--
            50 MB limit for CSV imports.
            Default IIS limit is 30 MB (maxAllowedContentLength = 30000000).
          -->
          <requestLimits maxAllowedContentLength="52428800" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
